def generate_director_stream(rtsp_url):
    cap = cv2.VideoCapture(rtsp_url, cv2.CAP_FFMPEG)

    if not cap.isOpened():
        print("Gagal membuka RTSP:", rtsp_url)
        return

    frame_w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    frame_h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

    director = SmoothDirector(
        frame_w=frame_w,
        frame_h=frame_h,
        min_zoom=1.0,
        max_zoom=2.6,
        target_fill=0.68,
        deadzone_px=55,
        zoom_deadzone=0.07,
        pan_speed=0.065,
        zoom_speed=0.018,
        prediction_strength=0.45,
    )

    failed_reads = 0

    while True:
        ret, frame = cap.read()

        if not ret:
            failed_reads += 1
            print(f"Director stream frame gagal: {failed_reads}")

            if failed_reads >= 20:
                cap.release()
                cap = cv2.VideoCapture(rtsp_url, cv2.CAP_FFMPEG)
                failed_reads = 0

            continue

        failed_reads = 0

        results = director_model(frame, conf=0.35, verbose=False)[0]

        player_boxes = []

        for r in results.boxes:
            cls_id = int(r.cls[0])
            label = director_model.names[cls_id]

            if label != "person":
                continue

            x1, y1, x2, y2 = r.xyxy[0].tolist()

            player_boxes.append(
                Box(
                    x1=float(x1),
                    y1=float(y1),
                    x2=float(x2),
                    y2=float(y2),
                )
            )

        crop_x1, crop_y1, crop_x2, crop_y2 = director.update(player_boxes)

        cropped = frame[crop_y1:crop_y2, crop_x1:crop_x2]

        if cropped.size == 0:
            output = frame
        else:
            output = cv2.resize(cropped, (1280, 720))

        cv2.putText(
            output,
            f"AI Director v0.4.58 | Players: {len(player_boxes)}",
            (25, 40),
            cv2.FONT_HERSHEY_SIMPLEX,
            1,
            (0, 255, 0),
            2,
        )

        ok, buffer = cv2.imencode(
            ".jpg",
            output,
            [cv2.IMWRITE_JPEG_QUALITY, 70],
        )

        if not ok:
            continue

        yield (
            b"--frame\r\n"
            b"Content-Type: image/jpeg\r\n\r\n" +
            buffer.tobytes() +
            b"\r\n"
        )

