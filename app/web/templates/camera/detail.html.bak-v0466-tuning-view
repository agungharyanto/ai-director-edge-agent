<script id="v0463-director-tuning-js">
(function(){
    const map = {
        pan_speed: "director_pan_speed",
        deadzone_x: "director_deadzone_x",
        deadzone_y: "director_deadzone_y",
        fixed_zoom: "director_fixed_zoom"
    };

    function val(key){
        return parseFloat(document.getElementById(map[key]).value);
    }

    function setVal(key, value){
        const el = document.getElementById(map[key]);
        if(!el) return;

        if(key === "pan_speed"){
            el.value = Number(value).toFixed(3);
        }else if(key === "fixed_zoom"){
            el.value = Number(value).toFixed(2);
        }else{
            el.value = parseInt(value);
        }
    }

    async function loadDirectorTuning(){
        const status = document.getElementById("directorTuningStatus");
        try{
            const r = await fetch("/camera/{{ camera['id'] }}/director-settings", {cache:"no-store"});
            const data = await r.json();

            if(data.success){
                Object.keys(map).forEach(function(k){
                    setVal(k, data.settings[k]);
                });
                status.innerHTML = "Director tuning: loaded.";
            }else{
                status.innerHTML = "Director tuning: load failed.";
            }
        }catch(e){
            status.innerHTML = "Director tuning: request error.";
        }
    }

    async function saveDirectorTuning(){
        const status = document.getElementById("directorTuningStatus");

        const payload = {
            pan_speed: val("pan_speed"),
            deadzone_x: val("deadzone_x"),
            deadzone_y: val("deadzone_y"),
            fixed_zoom: val("fixed_zoom")
        };

        status.innerHTML = "Director tuning: saving...";

        try{
            const r = await fetch("/camera/{{ camera['id'] }}/director-settings", {
                method: "POST",
                headers: {"Content-Type": "application/json"},
                body: JSON.stringify(payload)
            });

            const data = await r.json();

            if(data.success){
                Object.keys(map).forEach(function(k){
                    setVal(k, data.settings[k]);
                });
                status.innerHTML = "Director tuning: saved. Stream akan mengikuti setting baru otomatis.";
            }else{
                status.innerHTML = "Director tuning: save failed.";
            }
        }catch(e){
            status.innerHTML = "Director tuning: save request error.";
        }
    }

    document.querySelectorAll(".director-step").forEach(function(btn){
        btn.addEventListener("click", function(){
            const key = this.dataset.key;
            const step = parseFloat(this.dataset.step);
            const current = val(key);
            setVal(key, current + step);
            saveDirectorTuning();
        });
    });

    const saveBtn = document.getElementById("saveDirectorTuningBtn");
    if(saveBtn){
        saveBtn.addEventListener("click", saveDirectorTuning);
    }

    loadDirectorTuning();
})();
</script>


<script id="v0464-director-simulation-js">
(function(){
    function redrawDirectorSimulation(){
        if(typeof window.drawCalibration === "function"){
            window.drawCalibration();
        }
    }

    window.redrawDirectorSimulation = redrawDirectorSimulation;

    ["director_pan_speed", "director_deadzone_x", "director_deadzone_y", "director_fixed_zoom"].forEach(function(id){
        const el = document.getElementById(id);
        if(el){
            el.addEventListener("input", redrawDirectorSimulation);
            el.addEventListener("change", redrawDirectorSimulation);
        }
    });

    document.querySelectorAll(".director-step").forEach(function(btn){
        btn.addEventListener("click", function(){
            setTimeout(redrawDirectorSimulation, 150);
            setTimeout(redrawDirectorSimulation, 500);
        });
    });

    setTimeout(redrawDirectorSimulation, 800);
    setTimeout(redrawDirectorSimulation, 2000);
})();
</script>

