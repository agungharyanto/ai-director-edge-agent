<script>

async function refreshObjectHistory(){
    const box = document.getElementById("objectHistoryBox");
    if(!box) return;

    try{
        const r = await fetch("/camera/{{ camera['id'] }}/object-history", {
            cache: "no-store"
        });

        const data = await r.json();

        if(!data.success){
            box.innerHTML = "History not ready";
            return;
        }

        let lines = [];
        lines.push("Stats:");
        lines.push("  Player Tracks : " + data.stats.player_tracks);
        lines.push("  Player Points : " + data.stats.player_points);
        lines.push("  Ball Points   : " + data.stats.ball_points);
        lines.push("");

        lines.push("Players:");
        data.players.forEach(function(player){
            lines.push("  Player #" + player.track_id + " points=" + player.points.length);
            const last = player.points[player.points.length - 1];
            if(last){
                lines.push("    last x=" + last.court_x + " y=" + last.court_y);
            }
        });

        lines.push("");
        lines.push("Ball:");
        lines.push("  points=" + data.ball.length);
        const lastBall = data.ball[data.ball.length - 1];
        if(lastBall){
            lines.push("  last x=" + lastBall.court_x + " y=" + lastBall.court_y);
        }

        box.innerHTML = lines.join("\n");

    }catch(e){
        box.innerHTML = "History request error.";
    }
}


function renderAiCoordinates(data){
    const box = document.getElementById("aiCoordinateBox");
    if(!box) return;

    const c = data.ai_coordinates || {};

    if(!c.success){
        box.innerHTML = "Coordinate: " + (c.error || "not ready");
        return;
    }

    let lines = [];

    lines.push("Players:");
    if(c.players.length === 0){
        lines.push("  - none");
    }else{
        c.players.forEach(function(p){
            lines.push("  Player #" + p.track_id + "  x=" + p.court_x + "  y=" + p.court_y + "  conf=" + p.confidence);
        });
    }

    lines.push("");
    lines.push("Ball:");
    if(c.balls.length === 0){
        lines.push("  - none");
    }else{
        c.balls.forEach(function(b){
            lines.push("  Ball  x=" + b.court_x + "  y=" + b.court_y + "  conf=" + b.confidence);
        });
    }

    box.innerHTML = lines.join("\n");
}


function setSwitchState(inputId, enabled){
    const el = document.getElementById(inputId);
    if(el){
        el.checked = enabled;
    }
}

let statusTimer = null;
let clockTimer = null;
let streamStopped = false;
let lastStreamOnline = null;

let calibrationMode = false;
var calibrationPoints = [];
window.calibrationPoints = calibrationPoints;

const pointNames = [
    "top_left",
    "top_right",
    "bottom_right",
    "bottom_left"
];

const pointLabels = [
    "Top Left",
    "Top Right",
    "Bottom Right",
    "Bottom Left"
];

function pad(x){
    return String(x).padStart(2,"0");
}

function updateOverlayClock(){
    let d = new Date();
    let el = document.getElementById("overlayClock");

    if(!el) return;

    el.innerHTML =
        pad(d.getDate()) + "-" +
        pad(d.getMonth()+1) + "-" +
        d.getFullYear() + " " +
        pad(d.getHours()) + ":" +
        pad(d.getMinutes()) + ":" +
        pad(d.getSeconds());
}

async function refreshStreamStatus(){
    try{
        const r = await fetch("/camera/{{ camera['id'] }}/stream-status", {
            cache: "no-store"
        });

        const s = await r.json();

        const offline = document.getElementById("offlinePulse");
        if(offline){
            offline.style.display = s.online ? "none" : "block";
        }

        if(lastStreamOnline === false && s.online === true){
            const live = document.getElementById("live-stream");
            if(live){
                live.src = "/camera/{{ camera['id'] }}/stream?ts=" + new Date().getTime();
            }
        }

        lastStreamOnline = s.online;

        renderAiCoordinates(s);

        document.getElementById("streamStatus").innerHTML =
            "Online : " + s.online +
            "<br>Stale : " + s.stale +
            "<br>Frame : " + s.frame_count +
            "<br>Motion : " + s.motion +
            "<br>Player Detection : " + s.player_detection +
            "<br>Player Count : " + s.player_count +
            "<br>Ball Detection : " + s.ball_detection +
            "<br>Ball Count : " + s.ball_count +
            "<br>Error : " + (s.error || "-");

    }catch(e){
        renderAiCoordinates(s);

        document.getElementById("streamStatus").innerHTML = "Status error";
    }
}

function stopStream(){
    if(streamStopped) return;

    streamStopped = true;

    if(statusTimer){
        clearInterval(statusTimer);
    }

    if(clockTimer){
        clearInterval(clockTimer);
    }

    try{
        navigator.sendBeacon("/camera/{{ camera['id'] }}/stream-stop");
    }catch(e){
        fetch("/camera/{{ camera['id'] }}/stream-stop", {
            method: "POST",
            keepalive: true
        });
    }
}

function resizeCanvas(){
    const live = document.getElementById("live-stream");
    const canvas = document.getElementById("calibrationCanvas");

let draggingCalibrationPoint = null;
let dragMoved = false;

function getCanvasMouse(event){
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / Math.max(rect.width, 1);
    const scaleY = canvas.height / Math.max(rect.height, 1);

    return {
        x: Math.round((event.clientX - rect.left) * scaleX),
        y: Math.round((event.clientY - rect.top) * scaleY)
    };
}

function nearestCalibrationPoint(mouse){
    if(calibrationPoints.length === 0){
        return null;
    }

    let nearest = null;
    let nearestDistance = 999999;
    const radius = 28;

    calibrationPoints.forEach(function(p, index){
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const d = Math.sqrt(dx * dx + dy * dy);

        if(d < nearestDistance){
            nearestDistance = d;
            nearest = index;
        }
    });

    return nearestDistance <= radius ? nearest : null;
}

canvas.addEventListener("mousedown", function(event){
    const mouse = getCanvasMouse(event);
    const nearest = nearestCalibrationPoint(mouse);

    if(nearest !== null){
        draggingCalibrationPoint = nearest;
        dragMoved = false;
        canvas.style.cursor = "grabbing";
        calibrationModeLabel.innerHTML = "DRAG POINT " + (nearest + 1);
        event.preventDefault();
        event.stopPropagation();
        return false;
    }
}, true);

canvas.addEventListener("mousemove", function(event){
    const mouse = getCanvasMouse(event);

    if(draggingCalibrationPoint !== null){
        dragMoved = true;

        calibrationPoints[draggingCalibrationPoint] = {
            x: Math.max(0, Math.min(canvas.width, mouse.x)),
            y: Math.max(0, Math.min(canvas.height, mouse.y))
        };

        drawCalibration();
        updateCalibrationInfo();

        event.preventDefault();
        event.stopPropagation();
        return false;
    }

    const nearest = nearestCalibrationPoint(mouse);
    canvas.style.cursor = nearest !== null ? "grab" : "crosshair";
}, true);

window.addEventListener("mouseup", function(){
    if(draggingCalibrationPoint !== null){
        draggingCalibrationPoint = null;
        canvas.style.cursor = "crosshair";
        calibrationModeLabel.innerHTML = calibrationMode ? "CALIBRATION" : "VIEW";
        drawCalibration();
        updateCalibrationInfo();
    }
}, true);


    canvas.width = live.clientWidth;
    canvas.height = live.clientHeight;

    drawCalibration();
}

window.drawCalibration = function drawCalibration(){
    const canvas = document.getElementById("calibrationCanvas");
    const ctx = canvas.getContext("2d");

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if(calibrationPoints.length === 0){
        drawDirectorDeadzoneBox();
        return;
    }

    ctx.lineWidth = 3;
    ctx.strokeStyle = "lime";
    ctx.fillStyle = "rgba(0,255,0,0.18)";

    ctx.beginPath();
    calibrationPoints.forEach(function(p, i){
        if(i === 0){
            ctx.moveTo(p.x, p.y);
        }else{
            ctx.lineTo(p.x, p.y);
        }
    });

    if(calibrationPoints.length === 4){
        ctx.closePath();
        ctx.fill();
    }

    ctx.stroke();

    calibrationPoints.forEach(function(p, i){
        ctx.beginPath();
        ctx.arc(p.x, p.y, 7, 0, Math.PI * 2);
        ctx.fillStyle = "yellow";
        ctx.fill();

        ctx.lineWidth = 2;
        ctx.strokeStyle = "black";
        ctx.stroke();

        ctx.font = "bold 14px Arial";
        ctx.fillStyle = "white";
        ctx.strokeStyle = "black";
        ctx.lineWidth = 4;
        ctx.strokeText((i + 1) + ". " + pointLabels[i], p.x + 10, p.y - 10);
        ctx.fillText((i + 1) + ". " + pointLabels[i], p.x + 10, p.y - 10);
    });

    drawDirectorDeadzoneBox();
}


function drawDirectorDeadzoneBox(){
    const canvas = document.getElementById("calibrationCanvas");
    const ctx = canvas.getContext("2d");

    const panInput = document.getElementById("director_pan_speed");
    const deadXInput = document.getElementById("director_deadzone_x");
    const deadYInput = document.getElementById("director_deadzone_y");
    const zoomInput = document.getElementById("director_fixed_zoom");

    if(!deadXInput || !deadYInput || !zoomInput){
        return;
    }

    const deadX = parseFloat(deadXInput.value || 0);
    const deadY = parseFloat(deadYInput.value || 0);
    const panSpeed = panInput ? parseFloat(panInput.value || 0) : 0;
    const fixedZoom = Math.max(1, parseFloat(zoomInput.value || 1));

    const cx = canvas.width / 2;
    const cy = canvas.height / 2;

    // RED BOX = deadzone / no-pan area
    const deadLeft = Math.max(0, cx - deadX);
    const deadRight = Math.min(canvas.width, cx + deadX);
    const deadTop = Math.max(0, cy - deadY);
    const deadBottom = Math.min(canvas.height, cy + deadY);

    // BLUE BOX = fixed zoom crop simulation
    const cropW = canvas.width / fixedZoom;
    const cropH = canvas.height / fixedZoom;
    const cropLeft = Math.max(0, cx - cropW / 2);
    const cropTop = Math.max(0, cy - cropH / 2);

    ctx.save();

    // fixed zoom crop box
    ctx.lineWidth = 4;
    ctx.strokeStyle = "rgba(0, 130, 255, 0.95)";
    ctx.fillStyle = "rgba(0, 130, 255, 0.06)";
    ctx.beginPath();
    ctx.rect(cropLeft, cropTop, cropW, cropH);
    ctx.fill();
    ctx.stroke();

    ctx.font = "bold 14px Arial";
    ctx.fillStyle = "rgba(0, 130, 255, 1)";
    ctx.strokeStyle = "black";
    ctx.lineWidth = 4;
    ctx.strokeText("FIXED ZOOM CROP  " + fixedZoom.toFixed(2) + "x", cropLeft + 10, Math.max(22, cropTop + 22));
    ctx.fillText("FIXED ZOOM CROP  " + fixedZoom.toFixed(2) + "x", cropLeft + 10, Math.max(22, cropTop + 22));

    // deadzone box
    ctx.lineWidth = 5;
    ctx.strokeStyle = "rgba(255, 60, 0, 0.95)";
    ctx.fillStyle = "rgba(255, 60, 0, 0.08)";
    ctx.beginPath();
    ctx.rect(deadLeft, deadTop, deadRight - deadLeft, deadBottom - deadTop);
    ctx.fill();
    ctx.stroke();

    ctx.font = "bold 14px Arial";
    ctx.fillStyle = "rgba(255, 60, 0, 1)";
    ctx.strokeStyle = "black";
    ctx.lineWidth = 4;

    const label = "PAN DEADZONE  X:" + deadX + " Y:" + deadY + " | Pan Speed:" + panSpeed;

    ctx.strokeText(label, deadLeft + 10, Math.max(20, deadTop - 10));
    ctx.fillText(label, deadLeft + 10, Math.max(20, deadTop - 10));

    // center marker
    ctx.beginPath();
    ctx.arc(cx, cy, 5, 0, Math.PI * 2);
    ctx.fillStyle = "white";
    ctx.fill();
    ctx.lineWidth = 2;
    ctx.strokeStyle = "black";
    ctx.stroke();

    ctx.restore();
}

function updateCalibrationInfo(){
    let info = document.getElementById("calibrationInfo");
    let mode = document.getElementById("calibrationModeLabel");

    mode.innerHTML = calibrationMode ? "CALIBRATION" : "VIEW";

    if(calibrationPoints.length >= 4){
        info.innerHTML = "Calibration: 4/4 points ready. Klik Save Calibration.";
        return;
    }

    let next = pointLabels[calibrationPoints.length] || "-";
    info.innerHTML = "Calibration: " + calibrationPoints.length + "/4. Next: " + next;
}

function canvasClick(e){
    if(dragMoved){
        dragMoved = false;
        return;
    }

    if(!calibrationMode){
        return;
    }

    if(calibrationPoints.length >= 4){
        return;
    }

    const canvas = document.getElementById("calibrationCanvas");
    const rect = canvas.getBoundingClientRect();

    const x = Math.round(e.clientX - rect.left);
    const y = Math.round(e.clientY - rect.top);

    calibrationPoints.push({
        x: x,
        y: y
    });

    drawCalibration();
    updateCalibrationInfo();
}

async function loadCalibration(){
    try{
        const r = await fetch("/camera/{{ camera['id'] }}/calibration", {
            cache: "no-store"
        });

        const data = await r.json();

        if(data.success){
            calibrationPoints = [
                {x: data.top_left[0], y: data.top_left[1]},
                {x: data.top_right[0], y: data.top_right[1]},
                {x: data.bottom_right[0], y: data.bottom_right[1]},
                {x: data.bottom_left[0], y: data.bottom_left[1]}
            ];
        }

        drawCalibration();
        updateCalibrationInfo();

    }catch(e){
        document.getElementById("calibrationInfo").innerHTML = "Calibration: load error";
    }
}

async function saveCalibration(){
    if(calibrationPoints.length !== 4){
        alert("Harus klik 4 titik dulu.");
        return;
    }

    const payload = {
        top_left: [calibrationPoints[0].x, calibrationPoints[0].y],
        top_right: [calibrationPoints[1].x, calibrationPoints[1].y],
        bottom_right: [calibrationPoints[2].x, calibrationPoints[2].y],
        bottom_left: [calibrationPoints[3].x, calibrationPoints[3].y]
    };

    const r = await fetch("/camera/{{ camera['id'] }}/calibration", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
    });

    const data = await r.json();

    if(data.success){
        calibrationMode = false;
        document.getElementById("calibrationCanvas").style.pointerEvents = "auto";
        updateCalibrationInfo();
        alert("Calibration saved.");
    }else{
        alert("Save calibration failed.");
    }
}

