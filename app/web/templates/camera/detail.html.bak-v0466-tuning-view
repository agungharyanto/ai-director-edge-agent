<style>
.offline-pulse{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    z-index:40;
    background:rgba(220,53,69,.92);
    color:white;
    padding:18px 32px;
    border-radius:10px;
    font-size:24px;
    font-weight:bold;
    letter-spacing:2px;
    display:none;
    animation:offlinePulse 1s infinite;
}
@keyframes offlinePulse{
    0%{opacity:.45; transform:translate(-50%,-50%) scale(.98);}
    50%{opacity:1; transform:translate(-50%,-50%) scale(1.04);}
    100%{opacity:.45; transform:translate(-50%,-50%) scale(.98);}
}
</style>


<style>
.ai-switch-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-top:12px;
}
.ai-switch{
    position:relative;
    width:58px;
    height:30px;
}
.ai-switch input{
    opacity:0;
    width:0;
    height:0;
}
.ai-slider{
    position:absolute;
    cursor:pointer;
    top:0;
    left:0;
    right:0;
    bottom:0;
    background:#6c757d;
    transition:.25s;
    border-radius:30px;
}
.ai-slider:before{
    position:absolute;
    content:"";
    height:22px;
    width:22px;
    left:4px;
    bottom:4px;
    background:white;
    transition:.25s;
    border-radius:50%;
}
.ai-switch input:checked + .ai-slider{
    background:#28a745;
}
.ai-switch input:checked + .ai-slider:before{
    transform:translateX(28px);
}
</style>


